---
import { ALL_HEROES } from '@/data/heroes'
import { HeroDetail } from '@/components/HeroDetail'

export function getStaticPaths() {
  return ALL_HEROES.map((hero) => ({
    params: { id: hero.id },
    props: { hero },
  }))
}

const { hero } = Astro.props
const baseUrl = import.meta.env.BASE_URL
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{hero.name} - ホワサバ非公式Wiki</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body style="margin:0;padding:0;background-color:#09111f">
    <HeroDetail client:load hero={hero} baseUrl={baseUrl} />
  </body>
</html>
